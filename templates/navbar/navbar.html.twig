<nav class="navbar navbar-expand-lg bg-white border-bottom">
    <div class="container-fluid">
        <a class="navbar-brand fs-3" href="{{ path('home.index') }}">Hôtel</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarContent">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link {{ app.current_route starts with 'home.' ? 'active' : '' }}" href="{{ path('home.index') }}">Accueil</a>
                </li>
                {% if app.user %}
                    {% if is_granted('ROLE_ADMIN') %}
                        <li class="nav-item">
                            <a class="nav-link {{ app.current_route starts with 'hotel.' ? 'active' : '' }}" href="{{ path('admin.hotel.index') }}">Hôtel</a>
                        </li>
                    {% endif %}
                    <li class="nav-item">
                        <a class="nav-link {{ app.current_route starts with 'reservation.' ? 'active' : '' }}" href="{{ is_granted('ROLE_ADMIN') ? path('admin.reservation.index') : path('client.reservation.index') }}">Réservation</a>
                    </li>
                    {% if is_granted('ROLE_ADMIN') %}
                        <li class="nav-item">
                            <a class="nav-link {{ app.current_route starts with 'chambre.' ? 'active' : '' }}" href="{{ path('admin.chambre.index') }}">Chambre</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link {{ app.current_route starts with 'client.' ? 'active' : '' }}" href="{{ path('admin.client.index') }}">Client</a>
                        </li>
                    {% endif %}
                {% endif %}
            </ul>
            <ul class="navbar-nav align-items-center">
                {% if not app.user %}
                    <li class="nav-item">
                        <a class="nav-link {{ app.current_route starts with 'home.' ? 'active' : '' }}" href="{{ path('security.login') }}">Se connecter</a>
                    </li>
                {% else %}
                    <li class="nav-item">
                        <span class="navbar-text">Bonjour {{ app.user.getNomClient() }} !</span>
                    </li>
                    <li class="nav-item">
                        <form action="/logout" method="post">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
                            <button type="submit" class="btn btn-link nav-link" style="background: none;">Déconnexion</button>
                        </form>
                    </li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>
