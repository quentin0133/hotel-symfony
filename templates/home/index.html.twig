{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}
<h2 class="mb-4">Rechercher une chambre disponible</h2>
<form method="get" action="{{ path('home.index') }}" class="row g-3 align-items-end mb-4">
    <div class="col-auto">
        <label for="date_debut" class="form-label">Date d'arrivée</label>
        <input type="date" id="date_debut" name="date_debut" class="form-control"
               value="{{ dateDebut }}" required>
    </div>
    <div class="col-auto">
        <label for="date_fin" class="form-label">Date de départ</label>
        <input type="date" id="date_fin" name="date_fin" class="form-control"
               value="{{ dateFin }}" required>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Rechercher</button>
    </div>
</form>

{% if error %}
    <div class="alert alert-danger">{{ error }}</div>
{% endif %}

{% if chambresDisponibles is not null %}
    {% if chambresDisponibles is empty %}
        <div class="alert alert-warning">Aucune chambre disponible pour cette période.</div>
    {% else %}
        <p class="text-muted">{{ chambresDisponibles.getTotalItemCount() }} chambre(s) disponible(s) du
            <strong>{{ dateDebut|date('d/m/Y') }}</strong> au
            <strong>{{ dateFin|date('d/m/Y') }}</strong>
        </p>
        <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Code chambre</th>
                    <th>Hôtel</th>
                    <th>Type</th>
                    <th>Étage</th>
                    <th>Nombre de lits</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for chambre in chambresDisponibles %}
                    <tr>
                        <td>{{ chambre.codeChambre }}</td>
                        <td>{{ chambre.hotel.nomHotel }}</td>
                        <td>{{ chambre.type ? chambre.type.value : '-' }}</td>
                        <td>{{ chambre.etage ?? '-' }}</td>
                        <td>{{ chambre.nombreLit }}</td>
                        <td>
                            {% if not app.user %}
                                <a href="{{ path('security.login', {'_target_path': app.request.uri}) }}"
                                   class="btn btn-sm btn-outline-primary">
                                    Se connecter pour réserver
                                </a>
                            {% elseif not is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('client.reservation.new') }}"
                                   class="btn btn-sm btn-success">
                                    Réserver
                                </a>
                            {% endif %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
        </div>
        <div class="d-flex justify-content-center mt-4">
            {{ knp_pagination_render(chambresDisponibles) }}
        </div>
    {% endif %}
{% else %}
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
            <tr>
                <th>Code chambre</th>
                <th>Hôtel</th>
                <th>Type</th>
                <th>Étage</th>
                <th>Nombre de lits</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="text-center" colspan="10">
                        Veuillez entrer les dates afin d'accéder aux chambres disponibles
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
{% endif %}
{% endblock %}
