<form method="post" action="{{ path('client.delete', {'id': client.id}) }}" onsubmit="return confirm('Êtes-vous sûre que vous voulez supprimer ce client ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ client.id) }}">
    <button class="btn btn-danger py-2 d-inline-flex align-items-center justify-content-center">{{ ux_icon('bi:trash-fill') }}</button>
</form>
