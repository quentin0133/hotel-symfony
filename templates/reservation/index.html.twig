{% extends 'base.html.twig' %}

{% block title %}Gestion des Réservations{% endblock %}

{% block body %}
    <h1>Gestion des Réservations</h1>

    <a class="btn btn-primary my-2" href="{{ path('reservation.new') }}">Ajouter une réservation</a>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Date Début</th>
                <th>Date Fin</th>
                <th>Commentaire</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for reservation in reservations %}
            <tr>
                <td>{{ reservation.id }}</td>
                <td>{{ reservation.dateDebut ? reservation.dateDebut|date('d/m/Y') : '' }}</td>
                <td>{{ reservation.dateFin ? reservation.dateFin|date('d/m/Y') : '' }}</td>
                <td>{{ reservation.commentaire ? reservation.commentaire : '(Aucun commentaire)' }}</td>
                <td>
                    <div class="d-flex gap-1">
                        <a class="btn btn-primary py-2 d-inline-flex align-items-center justify-content-center" href="{{ path('reservation.show', {'id': reservation.id}) }}">{{ ux_icon('bi:eye-fill') }}</a>
                        <a class="btn btn-primary py-2 d-inline-flex align-items-center justify-content-center" href="{{ path('reservation.edit', {'id': reservation.id}) }}">{{ ux_icon('bi:pencil-fill') }}</a>
                        {% include 'reservation/_delete_form.html.twig' %}
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5" class="text-center">Aucune réservation trouvée</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
