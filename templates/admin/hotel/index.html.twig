{% extends 'base.html.twig' %}

{% block title %}Gestion des Hôtels{% endblock %}

{% block body %}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">
            {{ message }}
        </div>
    {% endfor %}

    <h1>Gestion des Hôtels</h1>

    <a class="btn btn-primary my-2" href="{{ path('admin.hotel.new') }}">Ajouter un hôtel</a>

    <form class="d-flex" method="get" action="{{ path('admin.hotel.index') }}">
        <input class="form-control me-2" name="search" type="search" placeholder="Rechercher..." aria-label="Search">
        <button class="btn btn-outline-success" type="submit">Rechercher</button>
    </form>

    <div class="table-responsive">
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Code Hôtel</th>
                <th>Nom Hôtel</th>
                <th>Adresse Hôtel</th>
                <th>Categorie Hôtel</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for hotel in hotels %}
            <tr>
                <td>{{ hotel.id }}</td>
                <td>{{ hotel.codeHotel }}</td>
                <td>{{ hotel.nomHotel }}</td>
                <td>{{ hotel.adresseHotel }}</td>
                <td>{{ hotel.categorieHotel }}</td>
                <td>
                    <div class="d-flex gap-1">
                        <a class="btn btn-primary py-2 d-inline-flex align-items-center justify-content-center" href="{{ path('admin.hotel.show', {'id': hotel.id}) }}">{{ ux_icon('bi:eye-fill') }}</a>
                        <a class="btn btn-primary py-2 d-inline-flex align-items-center justify-content-center" href="{{ path('admin.hotel.edit', {'id': hotel.id}) }}">{{ ux_icon('bi:pencil-fill') }}</a>
                        {% include 'admin/hotel/_delete_form.html.twig' %}
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6" class="text-center">Aucun hôtel trouvé</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    </div>

    <div class="d-flex justify-content-center mt-4">
        {{ knp_pagination_render(hotels) }}
    </div>
{% endblock %}
