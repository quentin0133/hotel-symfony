{% extends 'base.html.twig' %}

{% block title %}Gestion des Chambres{% endblock %}

{% block body %}
    <h1>Gestion des Chambres</h1>

    <a class="btn btn-primary my-2" href="{{ path('admin.chambre.new') }}">Ajouter une Chambre</a>

    <form class="d-flex" method="get" action="{{ path('admin.chambre.index') }}">
        <input class="form-control me-2" name="search" type="search" placeholder="Rechercher..." aria-label="Search">
        <button class="btn btn-outline-success" type="submit">Rechercher</button>
    </form>

    <div class="table-responsive">
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Code Chambre</th>
                <th>Étage</th>
                <th>Type</th>
                <th>Nombre Lit</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for chambre in chambres %}
            <tr>
                <td>{{ chambre.id }}</td>
                <td>{{ chambre.codeChambre }}</td>
                <td>{{ chambre.etage }}</td>
                <td>{{ chambre.type.value }}</td>
                <td>{{ chambre.nombreLit }}</td>
                <td>
                    <div class="d-flex gap-1">
                        <a class="btn btn-primary py-2 d-inline-flex align-items-center justify-content-center" href="{{ path('admin.chambre.show', {'id': chambre.id}) }}">{{ ux_icon('bi:eye-fill') }}</a>
                        <a class="btn btn-primary py-2 d-inline-flex align-items-center justify-content-center" href="{{ path('admin.chambre.edit', {'id': chambre.id}) }}">{{ ux_icon('bi:pencil-fill') }}</a>
                        {% include 'admin/chambre/_delete_form.html.twig' %}
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6" class="text-center">Aucune chambre trouvée</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
    </div>

    <div class="d-flex justify-content-center mt-4">
        {{ knp_pagination_render(chambres) }}
    </div>
{% endblock %}
