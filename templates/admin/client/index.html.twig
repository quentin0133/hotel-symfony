{% extends 'base.html.twig' %}

{% block title %}Gestion des Clients{% endblock %}

{% block body %}
    <h1>Gestion des Clients</h1>

    <a class="btn btn-primary my-2" href="{{ path('admin.client.new') }}">Ajouter un Client</a>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Email</th>
                <th>Rôles</th>
                <th>Code Client</th>
                <th>Nom Client</th>
                <th>Adresse Client</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for client in clients %}
            <tr>
                <td>{{ client.id }}</td>
                <td>{{ client.email }}</td>
                <td>{{ client.roles ? client.roles|json_encode : '' }}</td>
                <td>{{ client.codeClient }}</td>
                <td>{{ client.nomClient }}</td>
                <td>{{ client.adrClient }}</td>
                <td>
                    <div class="d-flex gap-1">
                        <a class="btn btn-primary py-2 d-inline-flex align-items-center justify-content-center" href="{{ path('admin.client.show', {'id': client.id}) }}">{{ ux_icon('bi:eye-fill') }}</a>
                        <a class="btn btn-primary py-2 d-inline-flex align-items-center justify-content-center" href="{{ path('admin.client.edit', {'id': client.id}) }}">{{ ux_icon('bi:pencil-fill') }}</a>
                        {% include 'admin/client/_delete_form.html.twig' %}
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="8" class="text-center">Aucun client trouvée</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
