{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié{% endblock %}

{% block body %}
    {% for flash_error in app.flashes('reset_password_error') %}
        <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
    {% endfor %}

    <div class="row justify-content-center">
        <div class="col-md-5">
            <h1 class="h3 mb-1">Mot de passe oublié ?</h1>
            <p class="text-muted mb-4">Saisissez votre adresse email et nous vous enverrons un lien pour réinitialiser votre mot de passe.</p>

            {{ form_start(requestForm, {'attr': {'class': 'd-flex flex-column gap-3'}}) }}
                {{ form_row(requestForm.email) }}
                <div class="d-flex align-items-center gap-3">
                    <button class="btn btn-primary">Envoyer le lien</button>
                    <a href="{{ path('security.login') }}" class="text-muted small">Retour à la connexion</a>
                </div>
            {{ form_end(requestForm) }}
        </div>
    </div>
{% endblock %}
