{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-md-5">
            <h1 class="h3 mb-1">Choisissez un nouveau mot de passe</h1>
            <p class="text-muted mb-4">Votre mot de passe doit contenir au moins 8 caractères.</p>

            {{ form_start(resetForm, {'attr': {'class': 'd-flex flex-column gap-3'}}) }}
                {{ form_row(resetForm.plainPassword) }}
                <div>
                    <button class="btn btn-primary">Réinitialiser le mot de passe</button>
                </div>
            {{ form_end(resetForm) }}
        </div>
    </div>
{% endblock %}
